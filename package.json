{
  "name": "lingjing-cli",
  "version": "0.2.0",
  "description": "CLI & MCP server for JDCloud Lingjing image/video generation APIs",
  "type": "module",
  "bin": {
    "lingjing": "./dist/cli.js",
    "lingjing-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js dist/mcp.js",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "jdcloud",
    "lingjing",
    "image-generation",
    "video-generation",
    "mcp",
    "model-context-protocol",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Algovate/lingjing-cli.git"
  },
  "homepage": "https://github.com/Algovate/lingjing-cli#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^14.0.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
